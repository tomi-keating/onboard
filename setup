#!/usr/bin/env python3
"""
MacSetup — Single entry point to configure a fresh macOS install.
Zero external dependencies. Uses Python 3 standard library only.
"""

import argparse
import json
import os
import shutil
import subprocess
import sys
import termios
import tty
from pathlib import Path
from typing import Optional


MANDATORY_APPS = {"Precheck", "Homebrew", "iTerm2", "Oh My Zsh"}


class C:
    """ANSI color codes"""

    CYAN = "\033[96m"
    GREEN = "\033[92m"
    YELLOW = "\033[93m"
    RED = "\033[91m"
    BOLD = "\033[1m"
    RESET = "\033[0m"


class SetupWizard:
    def __init__(self, catalog_path: Path):
        self.catalog_path = catalog_path
        self.catalog = self._load_catalog()
        self.log_path = Path(__file__).parent / "setup.log"
        self.selected = []
        self.successes = []
        self.skipped = []
        self.failures = []

    def _load_catalog(self):
        try:
            with open(self.catalog_path, "r", encoding="utf-8") as f:
                data = json.load(f)
                if isinstance(data, list):
                    return data
                # Fallback: support legacy categories schema
                apps = []
                for cat in data.get("categories", []):
                    for app in cat["apps"]:
                        app_copy = dict(app)
                        app_copy["category"] = cat["name"]
                        apps.append(app_copy)
                return apps
        except FileNotFoundError:
            print(f"{C.RED}Error: Catalog file not found at {self.catalog_path}{C.RESET}")
            sys.exit(1)
        except json.JSONDecodeError as exc:
            print(f"{C.RED}Error: Invalid JSON in catalog: {exc}{C.RESET}")
            sys.exit(1)

    @staticmethod
    def _has_homebrew() -> bool:
        return shutil.which("brew") is not None

    @staticmethod
    def _install_homebrew():
        print(f"{C.CYAN}Homebrew not found. Installing now...{C.RESET}")
        cmd = (
            '/bin/bash -c "$(curl -fsSL '
            'https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"'
        )
        result = subprocess.run(cmd, shell=True)
        if result.returncode != 0:
            print(
                f"{C.RED}Homebrew installation failed. "
                f"Please install manually and rerun.{C.RESET}"
            )
            sys.exit(1)

        # Ensure brew is in PATH for the remainder of this session
        arch = os.uname().machine
        brew_bin = "/opt/homebrew/bin" if arch == "arm64" else "/usr/local/bin"
        current_path = os.environ.get("PATH", "")
        if brew_bin not in current_path:
            os.environ["PATH"] = f"{brew_bin}:{current_path}"

        print(f"{C.GREEN}Homebrew installed successfully.{C.RESET}")

    @staticmethod
    def _update_brew_path():
        arch = os.uname().machine
        brew_bin = "/opt/homebrew/bin" if arch == "arm64" else "/usr/local/bin"
        current_path = os.environ.get("PATH", "")
        if brew_bin not in current_path:
            os.environ["PATH"] = f"{brew_bin}:{current_path}"

    def _load_log(self) -> dict:
        if not self.log_path.exists():
            return {}
        try:
            with open(self.log_path, "r", encoding="utf-8") as f:
                return json.load(f)
        except (json.JSONDecodeError, OSError):
            return {}

    def _save_log(self, results: dict):
        try:
            with open(self.log_path, "w", encoding="utf-8") as f:
                json.dump(results, f, indent=2)
        except OSError as exc:
            print(f"{C.YELLOW}Warning: Could not write log: {exc}{C.RESET}")

    @staticmethod
    def _prompt_retry_failed(log: dict) -> bool:
        failed = [name for name, status in log.items() if status == "failed"]
        if not failed:
            return False
        print(f"\n{C.YELLOW}Previous run had failures: {', '.join(failed)}{C.RESET}")
        while True:
            raw = input(
                f"{C.YELLOW}Retry only the failed apps? (y/n): {C.RESET}"
            ).strip().lower()
            if raw in ("y", "yes"):
                return True
            if raw in ("n", "no"):
                return False

    def _select_apps(self, all_apps: list, preselected_names: Optional[set] = None) -> list:
        """Interactive TUI for app selection. Returns list of selected app dicts."""
        app_names = [a["name"] for a in all_apps]
        selected = set(preselected_names) if preselected_names else set(app_names)
        # Ensure mandatory apps are always selected
        selected.update(n for n in app_names if n in MANDATORY_APPS)

        cursor = 0

        def render():
            print("\033[2J\033[3J\033[H", end="", flush=True)
            print(f"{C.BOLD}Select apps to install{C.RESET}")
            print("↑/↓: navigate  Space: toggle  Enter: confirm  q: quit")
            print()
            for i, app in enumerate(all_apps):
                name = app["name"]
                is_mandatory = name in MANDATORY_APPS
                is_selected = name in selected
                cursor_marker = ">" if i == cursor else " "
                if is_mandatory:
                    box = "[M]"
                else:
                    box = "[x]" if is_selected else "[ ]"
                desc = f" — {app['description']}" if app.get("description") else ""
                print(f"{cursor_marker} {box} {name}{desc}")
            print()

        def get_key():
            fd = sys.stdin.fileno()
            old = termios.tcgetattr(fd)
            try:
                tty.setraw(fd)
                ch = sys.stdin.read(1)
                if ch == "\x1b":
                    ch += sys.stdin.read(2)
                return ch
            finally:
                termios.tcsetattr(fd, termios.TCSADRAIN, old)

        print("\033[?25l", end="", flush=True)
        try:
            while True:
                render()
                key = get_key()
                if key in ("\r", "\n"):
                    break
                elif key in ("q", "\x03"):
                    print(f"\n{C.YELLOW}Cancelled by user.{C.RESET}")
                    sys.exit(0)
                elif key == "\x1b[A":
                    cursor = (cursor - 1) % len(all_apps)
                elif key == "\x1b[B":
                    cursor = (cursor + 1) % len(all_apps)
                elif key == " ":
                    name = all_apps[cursor]["name"]
                    if name not in MANDATORY_APPS:
                        if name in selected:
                            selected.remove(name)
                        else:
                            selected.add(name)
        finally:
            print("\033[?25h", end="", flush=True)

        return [a for a in all_apps if a["name"] in selected]

    @staticmethod
    def _check_apps(apps: list) -> tuple[list, list]:
        """Return (installed_apps, missing_apps) after checking upfront."""
        installed = []
        missing = []
        for app in apps:
            check = app.get("check")
            if check:
                result = subprocess.run(check, shell=True, capture_output=True)
                if result.returncode == 0:
                    installed.append(app)
                    continue
            missing.append(app)
        return installed, missing

    def _install(self):
        total = len(self.selected)
        if total == 0:
            print(f"\n{C.YELLOW}No apps selected. Exiting.{C.RESET}")
            return

        print(f"\n{C.BOLD}Installing {total} app(s)...{C.RESET}\n")
        for i, app in enumerate(self.selected, 1):
            name = app["name"]
            cmd = app["command"]

            print(f"{C.CYAN}[{i}/{total}] Installing {name}...{C.RESET}")
            result = subprocess.run(cmd, shell=True)
            if result.returncode == 0:
                print(f"{C.GREEN}✓ {name} installed successfully{C.RESET}")
                self.successes.append(name)
                if name == "Homebrew":
                    self._update_brew_path()
            else:
                print(f"{C.RED}✗ {name} installation failed{C.RESET}")
                self.failures.append(name)
                if name == "Precheck":
                    print(
                        f"\n{C.RED}Precheck failed. "
                        f"Stopping installation.{C.RESET}"
                    )
                    break

        # Summary
        print(f"\n{C.BOLD}=== Summary ==={C.RESET}")
        if self.successes:
            print(f"{C.GREEN}Installed: {len(self.successes)}{C.RESET}")
            for s in self.successes:
                print(f"  ✓ {s}")

        if self.skipped:
            print(f"{C.YELLOW}Already present: {len(self.skipped)}{C.RESET}")
            for s in self.skipped:
                print(f"  • {s}")

        if self.failures:
            print(f"{C.RED}Failed: {len(self.failures)}{C.RESET}")
            for f in self.failures:
                print(f"  ✗ {f}")
            print(
                f"\n{C.YELLOW}Run the script again to retry failed installations.{C.RESET}"
            )

        # Log results
        results = {}
        for name in self.successes:
            results[name] = "success"
        for name in self.skipped:
            results[name] = "skipped"
        for name in self.failures:
            results[name] = "failed"
        self._save_log(results)

    def _ensure_homebrew(self):
        if not self._has_homebrew():
            self._install_homebrew()
        else:
            print(f"{C.GREEN}Homebrew is already installed.{C.RESET}")

    @staticmethod
    def _report_skipped(installed_apps: list):
        if installed_apps:
            print(
                f"{C.GREEN}Skipping {len(installed_apps)} already installed app(s): "
                f"{', '.join(a['name'] for a in installed_apps)}{C.RESET}"
            )

    def run(self):
        self._ensure_homebrew()

        all_apps = self.catalog
        log = self._load_log()
        retry_failed = self._prompt_retry_failed(log)

        if retry_failed:
            preselected = {name for name, status in log.items() if status == "failed"}
        else:
            preselected = {a["name"] for a in all_apps}

        selected = self._select_apps(all_apps, preselected)

        # Check up front
        installed, missing = self._check_apps(selected)
        self._report_skipped(installed)
        self.skipped.extend(a["name"] for a in installed)
        self.selected.extend(missing)

        self._install()

    def run_non_interactive(self, category: Optional[str] = None):
        self._ensure_homebrew()

        all_apps = list(self.catalog)
        if category:
            target = category.lower()
            all_apps = [a for a in all_apps if a.get("category", "").lower() == target]

        # Check up front
        installed, missing = self._check_apps(all_apps)
        self._report_skipped(installed)
        self.skipped.extend(a["name"] for a in installed)
        self.selected.extend(missing)

        self._install()

    def list_apps(self):
        by_category = {}
        for app in self.catalog:
            cat = app.get("category", "Other")
            by_category.setdefault(cat, []).append(app)
        for cat, apps in by_category.items():
            print(f"\n{C.BOLD}{cat}{C.RESET}")
            for app in apps:
                desc = f" — {app['description']}" if app.get("description") else ""
                print(f"  • {app['name']}{desc}")


def main():
    parser = argparse.ArgumentParser(
        description="MacSetup — Single entry point to configure a fresh macOS install."
    )
    parser.add_argument(
        "--list", action="store_true", help="List available apps and exit"
    )
    parser.add_argument(
        "--install-all",
        action="store_true",
        help="Install every app non-interactively",
    )
    parser.add_argument(
        "--category", type=str, help="Install only a specific category non-interactively"
    )
    args = parser.parse_args()

    catalog = Path(__file__).parent / "apps.json"
    wizard = SetupWizard(catalog)

    try:
        if args.list:
            wizard.list_apps()
        elif args.install_all or args.category:
            wizard.run_non_interactive(category=args.category)
        else:
            wizard.run()
    except KeyboardInterrupt:
        print(f"\n{C.YELLOW}Interrupted by user. Exiting.{C.RESET}")
        sys.exit(0)


if __name__ == "__main__":
    main()
