{
  "categories": [
    {
      "name": "Core CLI Tools",
      "apps": [
        {
          "name": "Git",
          "command": "brew install git",
          "description": "Version control system",
          "check": "which git"
        },
        {
          "name": "curl",
          "command": "brew install curl",
          "description": "Command-line tool for transferring data with URLs",
          "check": "which curl"
        },
        {
          "name": "jq",
          "command": "brew install jq",
          "description": "Lightweight and flexible command-line JSON processor",
          "check": "which jq"
        },
        {
          "name": "yq",
          "command": "brew install yq",
          "description": "Portable command-line YAML processor",
          "check": "which yq"
        },
        {
          "name": "wget",
          "command": "brew install wget",
          "description": "Internet file retriever",
          "check": "which wget"
        },
        {
          "name": "GNU grep",
          "command": "brew install grep",
          "description": "GNU grep (installed as ggrep by default)",
          "check": "which ggrep"
        },
        {
          "name": "GNU findutils",
          "command": "brew install findutils",
          "description": "GNU find, xargs, and locate (installed as gfind, gxargs, glocate)",
          "check": "which gfind"
        },
        {
          "name": "GNU sed",
          "command": "brew install gnu-sed",
          "description": "GNU stream editor (installed as gsed by default)",
          "check": "which gsed"
        },
        {
          "name": "gawk",
          "command": "brew install gawk",
          "description": "GNU awk text processing engine",
          "check": "which gawk"
        },
        {
          "name": "less",
          "command": "brew install less",
          "description": "Pager program similar to more",
          "check": "which less"
        },
        {
          "name": "tree",
          "command": "brew install tree",
          "description": "Display directories as trees",
          "check": "which tree"
        },
        {
          "name": "fzf",
          "command": "brew install fzf",
          "description": "Command-line fuzzy finder",
          "check": "which fzf"
        }
      ]
    },
    {
      "name": "Terminal",
      "apps": [
        {
          "name": "iTerm2",
          "command": "brew install --cask iterm2",
          "description": "Popular terminal emulator for macOS",
          "check": "ls /Applications/iTerm.app"
        },
        {
          "name": "Oh My Zsh",
          "command": "sh scripts/install-oh-my-zsh.sh",
          "description": "A delightful, open-source, community-driven framework for managing your Zsh configuration",
          "check": "ls ~/.oh-my-zsh"
        }
      ]
    },
    {
      "name": "Development",
      "apps": [
        {
          "name": "nvm",
          "command": "sh scripts/install-nvm.sh",
          "description": "Node Version Manager - manage multiple active node.js versions",
          "check": "ls ~/.nvm"
        },
        {
          "name": "pyenv",
          "command": "sh scripts/install-pyenv.sh",
          "description": "Simple Python version management",
          "check": "which pyenv"
        },
        {
          "name": "gvm",
          "command": "sh scripts/install-gvm.sh",
          "description": "Go Version Manager",
          "check": "which gvm"
        }
      ]
    }
  ]
